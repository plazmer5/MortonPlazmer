<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

	<!-- app cache (safe, internal) -->
	<cache-path
        name="cache"
        path="." />

	<!-- app external files (Android/data/...) -->
	<external-files-path
        name="external_files"
        path="." />

	<!-- 🔥 Android 9 fallback: public Downloads -->
	<external-path
        name="downloads"
        path="Download/" />

</paths>