<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MortonPlazmer.Views.UpdatePage"
             Title="UpdatePage" BackgroundColor="Black">


    <VerticalStackLayout Padding="30" Spacing="20"
                         VerticalOptions="Center">

        <Label Text="Доступно обновление приложения!"
               FontSize="24" TextColor="White" FontAttributes="Bold" FontFamily="Arial"
               HorizontalOptions="Center"/>

        <ProgressBar x:Name="Progress" BackgroundColor="White"
                     Progress="0"/>

        <Label x:Name="StatusLabel" TextColor="White" 
               Text="Ожидание..."
               HorizontalOptions="Center"/>

        <Button Text="Скачать и установить"
                Clicked="OnUpdateClicked"/>
        <Button Text="Позже"
        Clicked="OnCancelClicked"/>
    </VerticalStackLayout>

</ContentPage>